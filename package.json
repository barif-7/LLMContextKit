{
  "name": "historykit",
  "version": "1.0.0",
  "description": "Local ChatGPT conversation search - fast, private, offline",
  "main": "dist-electron/main.js",
  "scripts": {
    "mcp:build": "cd historykit-mcp && npm install && npm run build",
    "mcp:start": "node historykit-mcp/dist/index.js",
    "mcp:install-claude": "node scripts/install-claude-mcp.js",
    "sync:chatgpt": "node scripts/sync-chatgpt-history.mjs",
    "import:claude": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/import-claude-export.mjs",

    "dev": "concurrently -n main,vite,electron -c cyan,green,yellow \"npm run compile-main\" \"vite\" \"npm run electron-dev\"",
    "compile-main": "tsc --watch --preserveWatchOutput",
    "electron-dev": "wait-on dist-electron/main.js tcp:4173 && cross-env NODE_ENV=development electron .",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.historykit.app",
    "productName": "HistoryKit",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "resources/icon.icns",
      "minimumSystemVersion": "12.0"
    },
    "files": ["dist/**/*", "dist-electron/**/*"],
    "extraResources": [
      {
        "from": "scripts/sync-chatgpt-history.mjs",
        "to": "scripts/sync-chatgpt-history.mjs"
      },
      {
        "from": "historykit-mcp",
        "to": "historykit-mcp",
        "filter": ["dist/**/*", "package.json", "node_modules/**/*"]
      }
    ],
    "directories": { "output": "release" }
  }
}
